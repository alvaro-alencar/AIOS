{
  "name": "@alvaro-alencar/aios",
  "version": "0.1.1",
  "description": "AIOS - Agent Intelligence Operating System: operational memory protocol and CLI for AI-assisted projects.",
  "type": "module",
  "bin": {
    "aios": "bin/aios.js"
  },
  "scripts": {
    "start": "node ./bin/aios.js",
    "check": "node --check ./bin/aios.js",
    "smoke": "node ./bin/aios.js --help && node ./bin/aios.js --version",
    "test": "node --test"
  },
  "keywords": [
    "ai",
    "agents",
    "memory",
    "cli",
    "documentation",
    "handoff",
    "protocol",
    "aios",
    "context"
  ],
  "author": "Alvaro Alencar",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alvaro-alencar/AIOS.git"
  },
  "homepage": "https://github.com/alvaro-alencar/AIOS#readme",
  "bugs": {
    "url": "https://github.com/alvaro-alencar/AIOS/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "bin/",
    "templates/",
    "spec/",
    "prompts/",
    "docs/",
    "README.md",
    "LICENSE"
  ]
}
